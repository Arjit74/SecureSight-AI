# GuardianLink Extension runtime settings
# Copy values into browser.storage.local via extension options/devtools if needed.

# Preferred backend endpoint for scans.
GUARDIANLINK_API_BASE=http://localhost:3000

# Fallback backend endpoint if local backend is not available.
GUARDIANLINK_API_FALLBACK=https://guardianlink-backend.onrender.com

# Set to true to enable extra debug logs in extension pages.
GUARDIANLINK_DEBUG=true
