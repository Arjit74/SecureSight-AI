# Server
PORT=3000
NODE_ENV=development

# API auth (recommended in production)
API_KEY=change-this-to-a-long-random-value

# CORS
# Comma-separated origins, for example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Request limits
REQUEST_SIZE_LIMIT=1mb
RATE_LIMIT_MAX=120
SCAN_RATE_LIMIT_MAX=30
SCAN_CACHE_TTL_MS=300000
SCAN_CACHE_MAX_ENTRIES=1000

# PostgreSQL (Option A: URL)
# DATABASE_URL=postgresql://user:password@localhost:5432/securesight
# PGSSLMODE=require

# PostgreSQL (Option B: discrete values)
PGHOST=localhost
PGPORT=5432
PGDATABASE=securesight
PGUSER=securesight_user
PGPASSWORD=change-this-password
